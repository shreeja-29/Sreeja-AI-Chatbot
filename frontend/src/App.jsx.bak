// ============================================================
// App.jsx — Root component with header + ChatBox
// ============================================================
import ChatBox from "./components/ChatBox";

// The person this assistant serves (override with VITE_USER_NAME in .env).
const USER_NAME = import.meta.env.VITE_USER_NAME || "Sreeja";

export default function App() {
  return (
    <div className="app">

      {/* ── Header ────────────────────────────────────────── */}
      <header className="header">
        <div className="header-logo">🤖</div>

        <div className="header-info">
          <div className="header-title">{USER_NAME}'s Personal Assistant</div>
          <div className="header-sub">Always here to help you</div>
        </div>

        <div className="header-badge">
          <span className="badge-dot" />
          Online
        </div>
      </header>

      {/* ── Chat Interface ─────────────────────────────────── */}
      <ChatBox />

    </div>
  );
}
