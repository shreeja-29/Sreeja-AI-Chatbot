# ============================================================
# Groq AI Chatbot - Backend Environment Variables (example)
# Copy this file to ".env" and fill in your own values.
# ============================================================

# Get a FREE API key at: https://console.groq.com/keys
# It starts with "gsk_" and is ~56 characters long.
GROQ_API_KEY=gsk_your_real_key_here

# Port the backend listens on.
PORT=5001

# ── Optional overrides ───────────────────────────────────────
# Chat model. Options on Groq include:
#   openai/gpt-oss-20b      ← OpenAI GPT, fast (current choice)
#   openai/gpt-oss-120b     ← OpenAI GPT, smartest
#   llama-3.1-8b-instant    ← Meta Llama, fast
#   llama-3.3-70b-versatile ← Meta Llama, larger
# Do NOT use the decommissioned mixtral-8x7b-32768 or llama3-8b-8192.
GROQ_MODEL=openai/gpt-oss-20b

# Comma-separated list of frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# The person this assistant serves (used in the system prompt).
USER_NAME=Sreeja

# Generation + safety limits. (gpt-oss models are reasoning models, so keep
# MAX_TOKENS generous — reasoning tokens count toward the completion budget.)
MAX_TOKENS=2048
TEMPERATURE=0.7
GROQ_TIMEOUT_MS=30000
MAX_MESSAGE_LEN=8000
MAX_HISTORY=20
